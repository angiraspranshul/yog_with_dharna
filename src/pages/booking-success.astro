---
import Layout from '../layouts/Layout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<Layout title="Booking Confirmed | Yoga with Dhaarna">
  <section class="min-h-[70vh] flex items-center justify-center py-20 px-6">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl shadow-olive/5 p-8 border border-olive/5 text-center">
      <div class="mx-auto w-16 h-16 bg-sage-light text-sage rounded-full flex items-center justify-center mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <h1 class="font-serif text-3xl italic text-olive">Booking Confirmed!</h1>
      <p class="text-olive/70 mt-4 leading-relaxed">
        Thank you for booking your session. Your payment has been successfully processed. 
        Dhaarna will contact you shortly with the class details and meeting link.
      </p>
      
      <div class="mt-8">
        <a 
          href={`${base}/classes/`}
          class="inline-block w-full bg-sage hover:bg-sage-dark text-white font-medium py-3 rounded-lg transition-colors"
        >
          Explore More Classes
        </a>
      </div>
    </div>
  </section>
</Layout>
