---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Instagram — Yoga with Dhaarna">
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <div class="max-w-xl">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-5xl">Instagram</h1>
      <p class="mt-4 text-lg text-slate-500">
        Daily inspiration, flows, and behind-the-scenes moments from the mat.
      </p>
      <a
        href="https://instagram.com/yogawithdhaarna"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-soft px-7 py-3 font-medium text-white shadow-sm shadow-soft/30 transition-all hover:-translate-y-0.5 hover:bg-soft-dark"
      >
        📷 Follow @yogawithdhaarna
      </a>
    </div>

    <!--
      Instagram feed widget placeholder.
      Paste the embed snippet from a feed service (e.g. Behold.so or Elfsight) inside the div below.
      Example (Behold): <div data-behold-id="YOUR_FEED_ID"></div> + their script tag.
    -->
    <div class="mt-12 rounded-2xl border border-dashed border-soft/40 bg-soft-light/50 p-12 text-center">
      <span class="text-4xl">✨</span>
      <p class="mt-4 font-medium text-slate-700">Live feed coming soon</p>
      <p class="mx-auto mt-2 max-w-sm text-sm text-slate-500">
        This space will show the latest posts from
        <a
          href="https://instagram.com/yogawithdhaarna"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-soft hover:text-soft-dark"
        >@yogawithdhaarna</a>.
      </p>
    </div>
  </section>
</Layout>
