---
import Layout from '../layouts/Layout.astro';

const gallery = [
  'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=700&q=80',
  'https://images.unsplash.com/photo-1575052814086-f385e2e2ad1b?auto=format&fit=crop&w=700&q=80',
  'https://images.unsplash.com/photo-1552196563-55cd4e45efb3?auto=format&fit=crop&w=700&q=80',
  'https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=700&q=80',
  'https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=700&q=80',
  'https://images.unsplash.com/photo-1588286840104-8957b019727f?auto=format&fit=crop&w=700&q=80',
];
---

<Layout title="Instagram — Yoga with Dhaarna">
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <div class="max-w-xl">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-5xl">Instagram</h1>
      <p class="mt-4 text-lg text-slate-500">
        Daily inspiration, flows, and behind-the-scenes moments from the mat.
      </p>
      <a
        href="https://instagram.com/yogawithdhaarna"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-soft px-7 py-3 font-medium text-white shadow-sm shadow-soft/30 transition-all hover:-translate-y-0.5 hover:bg-soft-dark"
      >
        📷 Follow @yogawithdhaarna
      </a>
    </div>

    <!--
      Preview gallery. To show the real live feed, paste an embed snippet from
      Behold.so or Elfsight here in place of the grid below.
    -->
    <div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3">
      {
        gallery.map((src) => (
          <a
            href="https://instagram.com/yogawithdhaarna"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block overflow-hidden rounded-2xl shadow-sm"
          >
            <img
              src={src}
              alt="Yoga with Dhaarna on Instagram"
              class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute inset-0 flex items-center justify-center bg-soft/0 text-white opacity-0 transition-all duration-300 group-hover:bg-soft/40 group-hover:opacity-100">
              View on Instagram ↗
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
