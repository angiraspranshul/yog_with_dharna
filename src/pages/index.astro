---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const classes = [
  {
    img: 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=900&q=80',
    name: 'Morning Hatha',
    duration: '60 min',
    level: 'Beginner',
    desc: 'Slow, grounding postures to greet the day with clarity.',
    price: 499,
  },
  {
    img: 'https://images.unsplash.com/photo-1575052814086-f385e2e2ad1b?auto=format&fit=crop&w=900&q=80',
    name: 'Vinyasa Flow',
    duration: '75 min',
    level: 'Intermediate',
    desc: 'Breath-led movement that builds warmth and quiet strength.',
    price: 699,
  },
  {
    img: 'https://images.unsplash.com/photo-1552196563-55cd4e45efb3?auto=format&fit=crop&w=900&q=80',
    name: 'Yin & Restore',
    duration: '60 min',
    level: 'All levels',
    desc: 'Long, supported holds that release what the day held onto.',
    price: 549,
  },
];

const journey = [
  { step: '01', title: 'Arrive', desc: 'Settle onto your mat. Leave the day at the door.' },
  { step: '02', title: 'Breathe', desc: 'Pranayama to soften the mind and steady the body.' },
  { step: '03', title: 'Flow', desc: 'Mindful movement, guided gently at your own pace.' },
  { step: '04', title: 'Restore', desc: 'Deep rest and stillness to carry with you after.' },
];

const carousel = [
  'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1545389336-cf090694435e?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1575052814086-f385e2e2ad1b?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1552196563-55cd4e45efb3?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1588286840104-8957b019727f?auto=format&fit=crop&w=800&q=80',
];
---

<Layout title="Yoga with Dhaarna — Find stillness. Move with breath." transparentNav>
  <!-- 1. Hero -->
  <section id="hero" class="relative flex min-h-screen items-center justify-center overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1545389336-cf090694435e?auto=format&fit=crop&w=2000&q=80"
      alt="Yoga practice at sunrise in the mountains"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-olive/55"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 pb-24 text-center">
      <h1 class="font-serif text-4xl italic leading-tight text-cream md:text-7xl">
        Find stillness.<br />Move with breath.
      </h1>
      <p class="mt-6 text-base text-cream/80 md:text-lg">
        Online &amp; in-person yoga with Dhaarna · Himachal Pradesh
      </p>
      <a
        href={`${base}/book/`}
        class="mt-10 inline-block rounded-full bg-gold px-9 py-4 font-medium text-olive shadow-lg shadow-olive/20 transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-dark"
      >
        Book your session
      </a>
      <p class="mt-5 text-sm text-cream/60">No commitment. Just a conversation.</p>
    </div>

    <!-- 2. Wave SVG divider -->
    <svg
      viewBox="0 0 1440 120"
      preserveAspectRatio="none"
      class="absolute bottom-0 left-0 h-16 w-full md:h-24"
      aria-hidden="true"
    >
      <path
        fill="#faf8f4"
        d="M0,64 C240,116 480,8 720,36 C960,64 1200,124 1440,60 L1440,120 L0,120 Z"
      />
    </svg>
  </section>

  <!-- 3. Philosophy -->
  <section class="mx-auto max-w-2xl px-6 py-24 text-center md:py-32">
    <p class="text-xs font-medium uppercase tracking-[0.25em] text-sage">The practice</p>
    <h2 class="mt-6 font-serif text-3xl italic leading-snug md:text-5xl">
      Yoga is not a workout.<br />It is a work-in.
    </h2>
    <p class="mx-auto mt-10 max-w-xl leading-loose text-olive/70">
      Dhaarna teaches yoga the way it was meant to be practised — slowly, attentively, and with
      the breath leading every movement. Her classes are not about touching your toes. They are
      about what you learn on the way down.
    </p>
    <p class="mx-auto mt-6 max-w-xl leading-loose text-olive/70">
      Rooted in the quiet of Himachal Pradesh and shaped by classical Hatha tradition, each
      session is an invitation to slow down, listen inward, and return to yourself.
    </p>
  </section>

  <!-- 4. Video -->
  <section class="mx-auto max-w-3xl px-6 pb-24">
    <!--
      Video placeholder: replace the poster + button below with a real player, e.g.
      <video controls poster="..." class="..."><source src="VIDEO_URL" type="video/mp4" /></video>
      or a YouTube/Vimeo iframe embed.
    -->
    <div class="group relative cursor-pointer overflow-hidden rounded-[2rem] shadow-xl shadow-olive/10">
      <img
        src="https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1400&q=80"
        alt="Dhaarna teaching a yoga class"
        class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-olive/25 transition-colors duration-300 group-hover:bg-olive/15"></div>
      <button
        type="button"
        aria-label="Play video"
        class="absolute left-1/2 top-1/2 flex h-20 w-20 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-cream/90 shadow-lg backdrop-blur transition-transform duration-300 group-hover:scale-110"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#2c3320" class="ml-1 h-8 w-8">
          <path d="M8 5.14v13.72L19 12 8 5.14z" />
        </svg>
      </button>
    </div>
    <p class="mt-5 text-center text-sm text-olive/50">Watch Dhaarna’s story</p>
  </section>

  <!-- 5. Classes -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="text-center">
      <p class="text-xs font-medium uppercase tracking-[0.25em] text-sage">Classes</p>
      <h2 class="mt-5 font-serif text-3xl italic md:text-5xl">Choose your practice</h2>
    </div>
    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        classes.map((c) => (
          <article class="group overflow-hidden rounded-[1.75rem] bg-white shadow-sm shadow-olive/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-olive/10">
            <div class="overflow-hidden">
              <img
                src={c.img}
                alt={c.name}
                class="h-56 w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-7">
              <div class="flex items-center justify-between">
                <h3 class="font-serif text-xl text-olive">{c.name}</h3>
                <span class="rounded-full bg-sage-light px-3 py-1 text-xs font-medium text-sage-dark">{c.level}</span>
              </div>
              <p class="mt-1 text-sm text-olive/50">{c.duration}</p>
              <p class="mt-3 text-sm leading-relaxed text-olive/70">{c.desc}</p>
              <div class="mt-6 flex items-center justify-between">
                <span class="font-serif text-lg text-olive">₹{c.price}</span>
                <a
                  href={`${base}/book/`}
                  class="rounded-full bg-sage px-6 py-2.5 text-sm font-medium text-cream transition-colors duration-300 hover:bg-sage-dark"
                >
                  Book
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- 6. Session journey -->
  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="text-center">
      <p class="text-xs font-medium uppercase tracking-[0.25em] text-sage">A session with Dhaarna</p>
      <h2 class="mt-5 font-serif text-3xl italic md:text-5xl">The journey of one hour</h2>
    </div>
    <div class="relative mt-16">
      <div class="absolute left-0 right-0 top-7 hidden h-px bg-sage/25 md:block" aria-hidden="true"></div>
      <div class="grid gap-10 md:grid-cols-4">
        {
          journey.map((j) => (
            <div class="relative text-center md:text-left">
              <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-sage font-serif text-cream md:mx-0">
                {j.step}
              </div>
              <h3 class="mt-5 font-serif text-xl text-olive">{j.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-olive/60">{j.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7. Photo carousel -->
  <section class="py-12">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <p class="text-xs font-medium uppercase tracking-[0.25em] text-sage">Moments</p>
      <h2 class="mt-5 font-serif text-3xl italic md:text-5xl">From the mat</h2>
    </div>
    <div class="no-scrollbar mt-12 flex snap-x snap-mandatory gap-5 overflow-x-auto px-6 pb-4 md:px-[max(1.5rem,calc((100vw-72rem)/2))]">
      {
        carousel.map((src) => (
          <a
            href="https://instagram.com/yogawithdhaarna"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative w-64 flex-none snap-center overflow-hidden rounded-[1.5rem] md:w-80"
          >
            <img
              src={src}
              alt="Yoga with Dhaarna"
              class="aspect-[4/5] w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute inset-0 flex items-end justify-start bg-gradient-to-t from-olive/40 to-transparent p-5 text-sm text-cream opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              @yogawithdhaarna ↗
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 8. Booking CTA banner -->
  <section class="mt-16 bg-sage">
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <h2 class="font-serif text-3xl italic text-cream md:text-5xl">Ready to begin?</h2>
      <p class="mx-auto mt-5 max-w-md text-cream/80">
        Your first session is a conversation, not a commitment. Come as you are.
      </p>
      <a
        href={`${base}/book/`}
        class="mt-10 inline-block rounded-full bg-cream px-9 py-4 font-medium text-olive shadow-lg shadow-olive/15 transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold"
      >
        Book your session
      </a>
    </div>
  </section>
</Layout>
