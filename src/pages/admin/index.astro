---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase/admin';

// Fetch classes from Firestore
let classes = [];
try {
  const snapshot = await adminDb.collection('classes').get();
  classes = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (error) {
  console.error("Error fetching classes:", error);
}
---

<AdminLayout title="Manage Classes">
  <div class="flex justify-between items-center mb-8">
    <h2 class="text-2xl font-bold text-gray-800">Classes</h2>
    <a href="/admin/classes/new" class="bg-sage hover:bg-sage-dark text-white px-4 py-2 rounded-lg font-medium transition-colors shadow-sm">
      + Add New Class
    </a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    {classes.length === 0 ? (
      <div class="p-8 text-center text-gray-500">
        No classes found. Click "Add New Class" to create one.
      </div>
    ) : (
      <ul class="divide-y divide-gray-200">
        {classes.map((cls) => (
          <li class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors">
            <div class="flex items-center gap-4">
              <div class="h-16 w-16 rounded-lg bg-gray-200 overflow-hidden flex-shrink-0">
                {cls.img ? (
                  <img src={cls.img} alt={cls.name} class="h-full w-full object-cover" />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-gray-400">No Img</div>
                )}
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{cls.name}</h3>
                <p class="text-sm text-gray-500">{cls.duration} • {cls.level}</p>
                <p class="text-sm font-medium text-sage-dark mt-1">₹{cls.price}</p>
              </div>
            </div>
            <div class="flex gap-2">
              <a 
                href={`/admin/classes/edit/${cls.id}`}
                class="text-sage-dark hover:text-sage font-medium text-sm px-3 py-1 rounded hover:bg-sage-light/20 transition-colors"
              >
                Edit
              </a>
              <button 
                class="delete-btn text-red-600 hover:text-red-800 text-sm font-medium px-3 py-1 rounded hover:bg-red-50 transition-colors"
                data-id={cls.id}
              >
                Delete
              </button>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <script>
    const deleteBtns = document.querySelectorAll('.delete-btn');
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        if(confirm('Are you sure you want to delete this class?')) {
          try {
            const res = await fetch(`/api/classes/${id}`, { method: 'DELETE' });
            if(res.ok) {
              window.location.reload();
            } else {
              alert('Failed to delete class');
            }
          } catch(err) {
            console.error(err);
            alert('Error deleting class');
          }
        }
      });
    });
  </script>
</AdminLayout>
