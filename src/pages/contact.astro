---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Yoga with Dhaarna">
  <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2 md:py-24">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-5xl">Get in touch</h1>
      <p class="mt-4 max-w-md text-lg text-slate-500">
        Questions about classes, private sessions, or workshops? Send a message and Dhaarna will get
        back to you soon.
      </p>
      <ul class="mt-10 space-y-4 text-slate-600">
        <li class="flex items-center gap-3">
          <span class="text-xl">📧</span>
          <a href="mailto:hello@yogawithdhaarna.com" class="transition-colors hover:text-soft">hello@yogawithdhaarna.com</a>
        </li>
        <li class="flex items-center gap-3">
          <span class="text-xl">📷</span>
          <a
            href="https://instagram.com/yogawithdhaarna"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-soft"
          >@yogawithdhaarna</a>
        </li>
        <li class="flex items-center gap-3">
          <span class="text-xl">📍</span>
          <span>India · Online classes worldwide</span>
        </li>
      </ul>
    </div>

    <!--
      Contact form via Formspree.
      Replace YOUR_FORM_ID in the action URL with the real Formspree form ID.
    -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="rounded-2xl border border-slate-100 bg-white/80 p-8 shadow-sm"
    >
      <div class="space-y-5">
        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-slate-700">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="Your name"
            class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors placeholder:text-slate-400 focus:border-soft focus:ring-2 focus:ring-soft/20"
          />
        </div>
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-slate-700">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors placeholder:text-slate-400 focus:border-soft focus:ring-2 focus:ring-soft/20"
          />
        </div>
        <div>
          <label for="message" class="mb-1.5 block text-sm font-medium text-slate-700">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder="How can Dhaarna help?"
            class="w-full resize-none rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors placeholder:text-slate-400 focus:border-soft focus:ring-2 focus:ring-soft/20"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-full bg-soft px-7 py-3 font-medium text-white shadow-sm shadow-soft/30 transition-colors hover:bg-soft-dark"
        >
          Send message
        </button>
      </div>
    </form>
  </section>
</Layout>
