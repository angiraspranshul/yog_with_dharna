---
import Layout from '../layouts/Layout.astro';
import { adminDb } from '../lib/firebase/admin';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const levelStyles: Record<string, string> = {
  Beginner: 'bg-soft-light text-soft-dark',
  Intermediate: 'bg-soft/15 text-soft-dark',
  Advanced: 'bg-soft text-white',
  'All levels': 'bg-slate-100 text-slate-600',
};

let classes = [];
try {
  const snapshot = await adminDb.collection('classes').get();
  classes = snapshot.docs.map(doc => ({ 
    id: doc.id, 
    icon: '🪷',
    ...doc.data() 
  }));
} catch (error) {
  console.error("Error fetching classes:", error);
}
---

<Layout title="Classes — Yoga with Dhaarna">
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <div class="max-w-xl">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-5xl">Classes</h1>
      <p class="mt-4 text-lg text-slate-500">
        From gentle morning flows to deep restorative sessions — find the practice that fits your rhythm.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        classes.map((c) => (
          <article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-100 bg-white/80 shadow-sm backdrop-blur transition-all hover:-translate-y-1 hover:shadow-md">
            <div class="relative overflow-hidden">
              <img
                src={c.img}
                alt={c.name}
                class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <span class="absolute left-4 top-4 rounded-full bg-white/85 px-2.5 py-1 text-lg shadow-sm backdrop-blur">{c.icon}</span>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h2 class="text-lg font-semibold text-slate-800">{c.name}</h2>
              <div class="mt-3 flex items-center gap-3 text-sm text-slate-500">
                <span>{c.duration}</span>
                <span class={`rounded-full px-3 py-1 text-xs font-medium ${levelStyles[c.level]}`}>{c.level}</span>
              </div>
              <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                <span class="text-lg font-semibold text-slate-900">₹{c.price}</span>
                <button
                  class="book-btn rounded-full bg-soft px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-soft-dark"
                  data-id={c.id}
                >
                  Book
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <script>
    const bookBtns = document.querySelectorAll('.book-btn');
    
    bookBtns.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const classId = target.dataset.id;
        
        target.innerText = "Processing...";
        target.disabled = true;

        try {
          // 1. Create Order
          const res = await fetch('/api/razorpay', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ classId })
          });
          
          if (!res.ok) throw new Error("Failed to initialize payment");
          
          const order = await res.json();

          // 2. Open Razorpay Checkout
          const options = {
            key: order.key, 
            amount: order.amount, 
            currency: order.currency,
            name: "Yoga with Dhaarna",
            description: "Class Booking",
            order_id: order.id,
            handler: async function (response: any) {
              // Payment succeeded
              try {
                const verifyRes = await fetch('/api/verify-payment', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    razorpay_order_id: response.razorpay_order_id,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_signature: response.razorpay_signature,
                    classId: classId
                  })
                });
                
                const verifyData = await verifyRes.json();
                if (verifyData.success) {
                  window.location.href = `/booking-success?payment_id=${response.razorpay_payment_id}`;
                } else {
                  alert("Payment verification failed. Please contact support.");
                }
              } catch (err) {
                console.error(err);
                alert("An error occurred during payment verification.");
              }
            },
            prefill: {
              name: "",
              email: "",
              contact: ""
            },
            theme: {
              color: "#6b8f71"
            }
          };

          const rzp1 = new (window as any).Razorpay(options);
          rzp1.on('payment.failed', function (response: any){
            alert("Payment failed. Please try again.");
          });
          rzp1.open();

        } catch (error) {
          console.error(error);
          alert("Could not process booking at this time.");
        } finally {
          target.innerText = "Book";
          target.disabled = false;
        }
      });
    });
  </script>
</Layout>
