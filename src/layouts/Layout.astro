---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  transparentNav?: boolean;
}

const {
  title = 'Yoga with Dhaarna',
  description = 'Online & in-person yoga with Dhaarna · Himachal Pradesh. Find stillness. Move with breath.',
  transparentNav = false,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/classes/`, label: 'Classes' },
  { href: `${base}/book/`, label: 'Book' },
  { href: `${base}/instagram/`, label: 'Instagram' },
  { href: `${base}/contact/`, label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script src="https://checkout.razorpay.com/v1/checkout.js" is:inline></script>
  </head>
  <body class="min-h-screen bg-cream font-sans text-olive antialiased">
    <header
      id="site-header"
      class={`top-0 z-30 w-full border-b border-olive/5 bg-cream/85 backdrop-blur transition-all duration-500 ease-out ${
        transparentNav ? 'fixed -translate-y-full opacity-0' : 'sticky'
      }`}
    >
      <nav class="relative mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={`${base}/`} class="font-serif text-xl italic tracking-tight text-olive">
          Yoga with Dhaarna
        </a>

        <input id="nav-toggle" type="checkbox" class="peer hidden" />
        <label
          for="nav-toggle"
          class="cursor-pointer rounded-lg p-2 text-olive/70 transition-colors hover:bg-cream-dark md:hidden"
          aria-label="Toggle navigation menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </label>

        <ul
          class="absolute left-0 top-full hidden w-full flex-col gap-1 border-b border-olive/5 bg-cream px-6 py-4 shadow-sm peer-checked:flex md:static md:flex md:w-auto md:flex-row md:items-center md:gap-9 md:border-0 md:bg-transparent md:p-0 md:shadow-none"
        >
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="block rounded-lg px-3 py-2 text-sm font-medium text-olive/70 transition-colors hover:bg-cream-dark hover:text-olive md:p-0 md:hover:bg-transparent md:hover:text-sage-dark"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 bg-olive text-cream">
      <div class="mx-auto max-w-6xl px-6 py-14">
        <div class="flex flex-col items-center gap-8 text-center md:flex-row md:items-start md:justify-between md:text-left">
          <div>
            <p class="font-serif text-2xl italic">Yoga with Dhaarna</p>
            <p class="mt-2 max-w-xs text-sm text-cream/60">Find stillness. Move with breath. Online &amp; in-person · Himachal Pradesh.</p>
          </div>
          <ul class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-cream/70">
            {
              links.map((link) => (
                <li>
                  <a href={link.href} class="transition-colors hover:text-cream">{link.label}</a>
                </li>
              ))
            }
          </ul>
          <a
            href="https://instagram.com/yogawithdhaarna"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-gold transition-colors hover:text-cream"
          >
            @yogawithdhaarna
          </a>
        </div>
        <p class="mt-12 border-t border-cream/10 pt-6 text-center text-xs text-cream/40">
          &copy; {new Date().getFullYear()} Yoga with Dhaarna. All rights reserved.
        </p>
        <p class="mt-3 text-center">
          <a href={`${base}/login`} class="text-[0.65rem] text-cream/20 transition-colors hover:text-cream/50">Admin</a>
        </p>
      </div>
    </footer>

    <script>
      // On pages with a full-screen hero, keep the navbar hidden while the hero
      // is in view and slide it in once the visitor scrolls past it.
      const header = document.getElementById('site-header');
      const hero = document.getElementById('hero');
      if (header && hero) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              header.classList.add('-translate-y-full', 'opacity-0');
            } else {
              header.classList.remove('-translate-y-full', 'opacity-0');
            }
          },
          { threshold: 0.12 }
        );
        observer.observe(hero);
      }
    </script>
  </body>
</html>
